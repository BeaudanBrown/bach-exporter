#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -eq 0 ]; then
  echo "Usage: $0 <command> [args...]" >&2
  exit 1
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cache_root="${XDG_CACHE_HOME:-$repo_root/.cache}"

if [ "${BACH_EXPORTER_IN_ENV:-}" = "1" ]; then
  exec "$@"
fi

mkdir -p "$cache_root"

exec env \
  BACH_EXPORTER_IN_ENV=1 \
  XDG_CACHE_HOME="$cache_root" \
  PRE_COMMIT_HOME="${PRE_COMMIT_HOME:-$repo_root/.pre-commit-cache}" \
  nix develop "$repo_root" -c "$@"
